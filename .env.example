# Copy this file's contents into Vercel → Project → Settings → Environment
# Variables (not into a local .env file that gets committed — keep secrets
# out of git).

# The password you'll type to log into /admin. Pick something only you know.
ADMIN_PASSWORD=

# Optional extra secret mixed into the session cookie hash. Any random
# string works — it doesn't need to be memorable.
ADMIN_SESSION_SECRET=

# A GitHub fine-grained personal access token with "Contents: Read and
# write" permission scoped to this one repo. Generate at:
# github.com -> Settings -> Developer settings -> Personal access tokens
# -> Fine-grained tokens -> Generate new token
GITHUB_TOKEN=

# Your GitHub username
GITHUB_OWNER=

# The repo name (as it appears in the GitHub URL)
GITHUB_REPO=

# Branch the admin panel commits to. Defaults to "main" if unset.
GITHUB_BRANCH=main
